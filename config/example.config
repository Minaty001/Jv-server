# example.config — Template for Render.com/Local Deployment

# 1. MongoDB Configuration
MONGO_URI = "mongodb+srv://<username>:<password>@<cluster>.mongodb.net/jarvis?retryWrites=true&w=majority"
DB_NAME = "jarvis_neural_core"

# 2. AI API Keys
GROQ_API_KEY = "gsk_..."
OPENAI_API_KEY = "sk-..."

# 3. Server Configuration
API_PORT = 10000
DEBUG_MODE = False

# ⚠️ INSTRUCTIONS:
# On Render.com, set these as Environment Variables (Settings -> Environment).
# Never commit your real API keys to GitHub!
